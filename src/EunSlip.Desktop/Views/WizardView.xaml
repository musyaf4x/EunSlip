<UserControl x:Class="EunSlip.Desktop.Views.WizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:EunSlip.Desktop.ViewModels"
             xmlns:c="clr-namespace:EunSlip.Desktop.Converters">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <c:NullToBoolConverter x:Key="NullToBool" />
        <c:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />

        <DataTemplate x:Key="SelectStep" DataType="{x:Type vm:PayrollWizardViewModel}">
            <Grid MaxWidth="720" Margin="0,8,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- File -->
                <StackPanel Grid.Row="0" Margin="0,0,0,24">
                    <TextBlock Text="FILE EXCEL (.XLSX)" Style="{StaticResource MicroLabel}" Margin="0,0,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding SelectedFilePath, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="True" Style="{StaticResource FieldInput}" Margin="0,0,8,0" />
                        <Button Content="PILIH FILE" Grid.Column="1" Click="PickFile_Click"
                                Style="{StaticResource OutlinedButton}" Padding="16,8" />
                    </Grid>
                </StackPanel>

                <!-- Period + date side by side -->
                <Grid Grid.Row="1" Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="PERIODE PAYROLL" Style="{StaticResource MicroLabel}" Margin="0,0,0,8" />
                        <TextBox Text="{Binding Period, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldInput}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="TANGGAL PEMBAYARAN" Style="{StaticResource MicroLabel}" Margin="0,0,0,8" />
                        <DatePicker SelectedDate="{Binding PaymentDate}" Style="{StaticResource FieldPicker}" />
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="2" Style="{StaticResource MutedText}"
                           Text="Contoh periode: JULY 2025. Tanggal pembayaran akan tampil di slip dengan format Indonesia." />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ValidateStep" DataType="{x:Type vm:PayrollWizardViewModel}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Style="{StaticResource BodyText}">
                        <Run Text="Penerima valid: " />
                        <Run Text="{Binding RecipientCount, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource CarbonInkBrush}" />
                    </TextBlock>
                </StackPanel>
                <Border Style="{StaticResource Card}" Padding="0">
                    <DataGrid ItemsSource="{Binding ValidationRows}" Style="{StaticResource EditorialDataGrid}"
                              AutoGenerateColumns="False" IsReadOnly="True" MinHeight="320">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="BARIS" Binding="{Binding RowNumber}" Width="60" />
                            <DataGridTextColumn Header="NIK" Binding="{Binding Nik}" Width="120" />
                            <DataGridTextColumn Header="NAMA" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="EMAIL" Binding="{Binding Email}" Width="*" />
                            <DataGridTextColumn Header="MASALAH" Binding="{Binding IssueSummary}" Width="220" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="PreviewStep" DataType="{x:Type vm:PayrollWizardViewModel}">
            <StackPanel MaxWidth="720">
                <Button Content="BUKA PRATINJAU PDF" Command="{Binding OpenPreviewCommand}"
                        Style="{StaticResource OutlinedButton}" Padding="20,10" Margin="0,0,0,24"
                        HorizontalAlignment="Left" />
                <TextBlock Text="SUBJEK EMAIL" Style="{StaticResource MicroLabel}" Margin="0,0,0,8" />
                <TextBox Text="{Binding EmailSubject, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FieldInput}" Margin="0,0,0,20" />
                <TextBlock Text="ISI EMAIL" Style="{StaticResource MicroLabel}" Margin="0,0,0,8" />
                <TextBox Text="{Binding EmailBody, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" Height="160"
                         Style="{StaticResource FieldInput}" Margin="0,0,0,20" />
                <Border Background="{StaticResource FogBrush}" Padding="16,10" CornerRadius="4" Margin="0,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource MutedText}" Margin="0,0,16,0">
                            <Run Text="Penerima: " /><Run Text="{Binding RecipientCount, Mode=OneWay}" Foreground="{StaticResource CarbonInkBrush}" />
                        </TextBlock>
                        <TextBlock Style="{StaticResource MutedText}" Margin="0,0,16,0">
                            <Run Text="Gmail: " /><Run Text="{Binding HasGmailConnection, Mode=OneWay}" Foreground="{StaticResource CarbonInkBrush}" />
                        </TextBlock>
                        <TextBlock Style="{StaticResource MutedText}">
                            <Run Text="Stamp: " /><Run Text="{Binding HasStamp, Mode=OneWay}" Foreground="{StaticResource CarbonInkBrush}" />
                        </TextBlock>
                    </StackPanel>
                </Border>
                <TextBlock Style="{StaticResource MutedText}" Margin="0,12,0,0"
                           Text="Gmail dan stamp harus siap sebelum konfirmasi kirim (di langkah berikutnya)." />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="ConfirmStep" DataType="{x:Type vm:PayrollWizardViewModel}">
            <StackPanel MaxWidth="560">
                <Border Background="{StaticResource FogBrush}" Padding="20,16" CornerRadius="4" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,8">
                            <Run Text="Penerima: " /><Run Text="{Binding RecipientCount, Mode=OneWay}" FontWeight="SemiBold" />
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,8">
                            <Run Text="Gmail: " /><Run Text="{Binding ConnectedGmail, Mode=OneWay}" FontWeight="SemiBold" />
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}">
                            <Run Text="Periode: " /><Run Text="{Binding Period, Mode=OneWay}" FontWeight="SemiBold" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Prerequisite checklist -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="PRASYARAT KIRIM" Style="{StaticResource MicroLabel}" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="{Binding GmailReady, Mode=OneWay}" Style="{StaticResource BodyText}"
                                   Foreground="{StaticResource EmberRedBrush}" FontWeight="SemiBold" Width="24" />
                        <TextBlock Text="Gmail terhubung" Style="{StaticResource BodyText}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding StampReady, Mode=OneWay}" Style="{StaticResource BodyText}"
                                   Foreground="{StaticResource EmberRedBrush}" FontWeight="SemiBold" Width="24" />
                        <TextBlock Text="Stamp aktif" Style="{StaticResource BodyText}" />
                    </StackPanel>
                    <TextBlock Text="Lengkapi di Pengaturan jika ada yang belum siap."
                               Style="{StaticResource MutedText}" Margin="24,8,0,0"
                               Visibility="{Binding IsReadyToConfirm, Converter={StaticResource InverseBoolToVis}}" />
                </StackPanel>

                <Border Background="{StaticResource FogBrush}" BorderBrush="{StaticResource EmberRedBrush}"
                        BorderThickness="2,0,0,0" Padding="16,12" Margin="0,0,0,24">
                    <TextBlock Style="{StaticResource BodyText}" Text="Pengiriman tidak dapat dihentikan setelah konfirmasi." />
                </Border>
                <Button Content="KONFIRMASI &amp; KIRIM" Command="{Binding ConfirmSendCommand}"
                        Style="{StaticResource PrimaryButton}" Padding="24,12" HorizontalAlignment="Left" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="SendStep" DataType="{x:Type vm:PayrollWizardViewModel}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left" MaxWidth="480">
                <TextBlock Text="MENGIRIM" Style="{StaticResource MicroLabel}" Margin="0,0,0,8" />
                <TextBlock Text="{Binding StatusMessage, Mode=OneWay}" Style="{StaticResource SectionHeading}" Margin="0,0,0,24" />
                <TextBlock Style="{StaticResource DisplayHeading}" FontSize="48" Margin="0,0,0,16">
                    <Run Text="{Binding CurrentRecipient, Mode=OneWay}" /><Run Text=" / " /><Run Text="{Binding TotalRecipients, Mode=OneWay}" />
                </TextBlock>
                <TextBlock Style="{StaticResource MutedText}" Margin="0,0,0,4">
                    <Run Text="NIK: " /><Run Text="{Binding CurrentNik, Mode=OneWay}" Foreground="{StaticResource CarbonInkBrush}" />
                </TextBlock>
                <TextBlock Style="{StaticResource MutedText}" Margin="0,0,0,4">
                    <Run Text="Nama: " /><Run Text="{Binding CurrentName, Mode=OneWay}" Foreground="{StaticResource CarbonInkBrush}" />
                </TextBlock>
                <TextBlock Style="{StaticResource MutedText}" Margin="0,0,0,16">
                    <Run Text="Percobaan: " /><Run Text="{Binding CurrentAttempt, Mode=OneWay}" Foreground="{StaticResource CarbonInkBrush}" />
                </TextBlock>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                    <TextBlock Style="{StaticResource BodyText}" Margin="0,0,24,0">
                        <Run Text="Terkirim " /><Run Text="{Binding SentCount, Mode=OneWay}" FontWeight="SemiBold" />
                    </TextBlock>
                    <TextBlock Style="{StaticResource BodyText}">
                        <Run Text="Gagal " /><Run Text="{Binding FailedCount, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource EmberRedBrush}" />
                    </TextBlock>
                </StackPanel>
                <TextBlock Text="Jangan tutup aplikasi." Style="{StaticResource MutedText}" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="ResultsStep" DataType="{x:Type vm:PayrollWizardViewModel}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock Style="{StaticResource SectionHeading}" Margin="0,0,24,0">
                        <Run Text="Terkirim " /><Run Text="{Binding SentCount, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock Style="{StaticResource SectionHeading}">
                        <Run Text="Gagal " /><Run Text="{Binding FailedCount, Mode=OneWay}" Foreground="{StaticResource EmberRedBrush}" />
                    </TextBlock>
                </StackPanel>
                <Border Style="{StaticResource Card}" Padding="0">
                    <DataGrid ItemsSource="{Binding Results}" Style="{StaticResource EditorialDataGrid}"
                              AutoGenerateColumns="False" IsReadOnly="True" MinHeight="320">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="NIK" Binding="{Binding Nik}" Width="120" />
                            <DataGridTextColumn Header="NAMA" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="EMAIL" Binding="{Binding Email}" Width="*" />
                            <DataGridTextColumn Header="PERC." Binding="{Binding AttemptsMade}" Width="70" />
                            <DataGridTextColumn Header="ALASAN" Binding="{Binding ErrorMessage}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{StaticResource PaperWhiteBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="40,36,40,0">
            <TextBlock Text="{Binding StepTitle}" Style="{StaticResource DisplayHeading}" FontSize="26" />
            <Border Background="{StaticResource MistBrush}" Height="1" Margin="0,16,0,0" />
            <TextBlock Text="{Binding ErrorMessage, Mode=OneWay}" Foreground="{StaticResource EmberRedBrush}"
                       FontFamily="{StaticResource BodyFont}" FontSize="13" Margin="0,12,0,0"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}" />
        </StackPanel>

        <ContentControl Grid.Row="1" Content="{Binding}" Margin="40,24,40,0">
            <ContentControl.Style>
                <Style TargetType="ContentControl">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentStep}" Value="Select">
                            <Setter Property="ContentTemplate" Value="{StaticResource SelectStep}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurrentStep}" Value="Validate">
                            <Setter Property="ContentTemplate" Value="{StaticResource ValidateStep}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurrentStep}" Value="Preview">
                            <Setter Property="ContentTemplate" Value="{StaticResource PreviewStep}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurrentStep}" Value="Confirm">
                            <Setter Property="ContentTemplate" Value="{StaticResource ConfirmStep}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurrentStep}" Value="Send">
                            <Setter Property="ContentTemplate" Value="{StaticResource SendStep}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurrentStep}" Value="Results">
                            <Setter Property="ContentTemplate" Value="{StaticResource ResultsStep}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>
        </ContentControl>

        <Grid Grid.Row="2" Margin="40,0,40,36">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Content="KEMBALI" Command="{Binding BackCommand}" Grid.Column="1"
                    Style="{StaticResource OutlinedButton}" Margin="0,0,8,0" Padding="20,10"
                    Visibility="{Binding CanGoBack, Converter={StaticResource BoolToVis}}" />
            <Button Content="LANJUT" Command="{Binding NextCommand}" Grid.Column="2"
                    Style="{StaticResource PrimaryButton}" Padding="20,10"
                    Visibility="{Binding CanGoNext, Converter={StaticResource BoolToVis}}" />
        </Grid>
    </Grid>
</UserControl>
