<UserControl x:Class="EunSlip.Desktop.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:EunSlip.Desktop.Converters">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <c:NullToBoolConverter x:Key="NullToBool" />
        <c:NullToVisibilityConverter x:Key="NullToVis" />
        <c:NullToVisibilityInverseConverter x:Key="NullToVisInverse" />
    </UserControl.Resources>
    <Grid Background="{StaticResource PaperWhiteBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="40,36,40,0">
            <TextBlock Text="Riwayat Batch" Style="{StaticResource DisplayHeading}" FontSize="26" />
            <Border Background="{StaticResource MistBrush}" Height="1" Margin="0,16,0,0" />
        </StackPanel>

        <!-- Toolbar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="40,20,40,0">
            <Button Content="KIRIM ULANG GAGAL" Command="{Binding RetryFailedCommand}"
                    CommandParameter="{Binding SelectedBatch}" Style="{StaticResource OutlinedButton}"
                    Padding="16,8" Margin="0,0,8,0"
                    IsEnabled="{Binding SelectedBatch, Converter={StaticResource NullToBool}}" />
            <Button Content="PULIHKAN" Command="{Binding RecoverCommand}"
                    CommandParameter="{Binding SelectedBatch}" Style="{StaticResource OutlinedButton}"
                    Padding="16,8" Margin="0,0,8,0"
                    IsEnabled="{Binding SelectedBatch, Converter={StaticResource NullToBool}}" />
            <Button Content="HAPUS" Command="{Binding RequestDeleteCommand}"
                    CommandParameter="{Binding SelectedBatch}" Style="{StaticResource OutlinedButton}"
                    Padding="16,8"
                    IsEnabled="{Binding SelectedBatch, Converter={StaticResource NullToBool}}" />
            <TextBlock Text="{Binding StatusMessage, Mode=OneWay}" Style="{StaticResource MutedText}"
                       VerticalAlignment="Center" Margin="16,0,0,0" />
        </StackPanel>

        <!-- Batch list -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0" Margin="40,16,40,8">
            <DataGrid ItemsSource="{Binding Batches}" Style="{StaticResource EditorialDataGrid}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectedItem="{Binding SelectedBatch}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="PERIODE" Binding="{Binding Period}" Width="120" />
                    <DataGridTextColumn Header="TANGGAL" Binding="{Binding PaymentDate}" Width="130" />
                    <DataGridTextColumn Header="PENERIMA" Binding="{Binding RecipientCount}" Width="90" />
                    <DataGridTextColumn Header="KIRIM" Binding="{Binding SentCount}" Width="70" />
                    <DataGridTextColumn Header="GAGAL" Binding="{Binding FailedCount}" Width="70" />
                    <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Detail recipients -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0" Margin="40,0,40,32" Height="160">
            <Grid>
                <DataGrid ItemsSource="{Binding SelectedRecipients}" Style="{StaticResource EditorialDataGrid}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          Visibility="{Binding SelectedBatch, Converter={StaticResource NullToVisInverse}}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="NIK" Binding="{Binding NikHint}" Width="140" />
                        <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" Width="120" />
                        <DataGridTextColumn Header="DIPERBARUI" Binding="{Binding LastUpdatedAtUtc}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
                <TextBlock Text="Pilih batch di atas untuk melihat detail penerima."
                           Style="{StaticResource MutedText}" Margin="20"
                           VerticalAlignment="Center"
                           Visibility="{Binding SelectedBatch, Converter={StaticResource NullToVis}}" />
            </Grid>
        </Border>

        <!-- Delete confirmation -->
        <Border Grid.Row="4" Background="{StaticResource FogBrush}" BorderBrush="{StaticResource EmberRedBrush}"
                BorderThickness="2,0,0,0" Padding="20,12" Margin="40,0,40,32"
                Visibility="{Binding ConfirmDelete, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Hapus permanen batch ini? Riwayat tak bisa dikembalikan."
                           Style="{StaticResource BodyText}" VerticalAlignment="Center" Margin="0,0,16,0" />
                <Button Content="HAPUS PERMANEN" Command="{Binding ConfirmDeleteBatchCommand}"
                        Style="{StaticResource PrimaryButton}" Padding="14,6" Margin="0,0,8,0" />
                <Button Content="BATAL" Command="{Binding CancelDeleteCommand}"
                        Style="{StaticResource OutlinedButton}" Padding="14,6" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
