<UserControl x:Class="EunSlip.Desktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <x:Array x:Key="Languages" Type="{x:Type sys:String}">
            <sys:String>id-ID</sys:String>
            <sys:String>en-US</sys:String>
        </x:Array>
    </UserControl.Resources>
    <ScrollViewer Background="{StaticResource PaperWhiteBrush}">
        <StackPanel Margin="40,32" MaxWidth="640">

            <TextBlock Text="Pengaturan" Style="{StaticResource DisplayHeading}" FontSize="28" Margin="0,0,0,24" />

            <!-- Gmail -->
            <TextBlock Text="GMAIL" Style="{StaticResource MicroLabel}" Margin="0,0,0,8" />
            <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,4">
                        <Run Text="Akun: " /><Run Text="{Binding ConnectedGmail, Mode=OneWay}" Foreground="{StaticResource GraphiteBrush}" />
                    </TextBlock>
                    <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,12">
                        <Run Text="Terkoneksi: " /><Run Text="{Binding HasGmailConnection, Mode=OneWay}" Foreground="{StaticResource GraphiteBrush}" />
                    </TextBlock>
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding ConnectGmailCommand}"
                                Padding="16,8" Margin="0,0,8,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                    <Setter Property="Content" Value="HUBUNGKAN" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnecting}" Value="True">
                                            <Setter Property="Content" Value="MENGHUBUNGKAN…" />
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="PUTUSKAN" Command="{Binding DisconnectGmailCommand}"
                                Style="{StaticResource OutlinedButton}" Padding="16,8" />
                    </StackPanel>
                    <TextBlock Text="{Binding StatusMessage, Mode=OneWay}" Style="{StaticResource MutedText}"
                               Margin="0,12,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Setup guide -->
            <Expander Header="PANDUAN SETUP GOOGLE CLOUD &amp; OAUTH" Margin="0,0,0,24"
                      FontFamily="{StaticResource BodyFont}" FontSize="12" FontWeight="SemiBold"
                      Foreground="{StaticResource SlateBrush}" Padding="0">
                <Border Background="{StaticResource FogBrush}" Padding="16,12" CornerRadius="4" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource BodyText}" FontWeight="SemiBold" Margin="0,0,0,8" Text="Langkah-langkah:" />
                        <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,6">
                            <Run Text="1. Buka " /><Run Text="console.cloud.google.com" /><Run Text=" → buat / pilih project." />
                        </TextBlock>
                        <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,6">
                            <Run Text="2. APIs &amp; Services → Library → aktifkan " /><Run Text="Gmail API" /><Run Text="." />
                        </TextBlock>
                        <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,6">
                            <Run Text="3. OAuth consent screen: pilih " /><Run Text="Internal" /><Run Text=" (jika Google Workspace), isi app name &amp; email." />
                        </TextBlock>
                        <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,6">
                            <Run Text="4. Credentials → Create Credentials → OAuth client ID → type " /><Run Text="Desktop app" /><Run Text="." />
                        </TextBlock>
                        <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,6">
                            <Run Text="5. Download " /><Run Text="client_secret.json" /><Run Text="." />
                        </TextBlock>
                        <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,6">
                            <Run Text="6. Buka isi file client_secret.json, tempel ke kotak " /><Run Text="Kredensial OAuth" /><Run Text=" di bawah, klik Simpan." />
                        </TextBlock>
                        <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,6">
                            <Run Text="7. Klik " /><Run Text="Hubungkan" /><Run Text=" — browser terbuka, login akun payroll Gmail, izinkan." />
                        </TextBlock>
                        <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,0" Foreground="{StaticResource EmberRedBrush}">
                            <Run Text="Catatan: gunakan akun payroll Gmail (PT. EUNSUNG INDONESIA). Akun ini jadi pengirim." />
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Expander>

            <!-- OAuth credential -->
            <TextBlock Text="KREDENSIAL OAUTH" Style="{StaticResource MicroLabel}" Margin="0,0,0,8" />
            <Border Style="{StaticResource Card}" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Style="{StaticResource MutedText}" Margin="0,0,0,4"
                               Text="{Binding HasOAuthSecret, StringFormat='Tersimpan: {0}'}" />
                    <TextBlock Text="Tempel client_secret.json dari Google Cloud Console. Disimpan terenkripsi (DPAPI)."
                               Style="{StaticResource MutedText}" Margin="0,0,0,12" />
                    <TextBox Text="{Binding OauthClientSecretJson, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" Height="100"
                             Style="{StaticResource FieldInput}" Margin="0,0,0,12" />
                    <Button Content="SIMPAN" Command="{Binding SaveOAuthSecretCommand}"
                            Style="{StaticResource PrimaryButton}" Padding="16,8" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <!-- Stamp -->
            <TextBlock Text="STAMP" Style="{StaticResource MicroLabel}" Margin="0,0,0,8" />
            <Border Style="{StaticResource Card}" Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,12">
                        <Run Text="Stamp aktif: " /><Run Text="{Binding HasStamp, Mode=OneWay}" Foreground="{StaticResource GraphiteBrush}" />
                    </TextBlock>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="PILIH GAMBAR" Click="PickStamp_Click"
                                Style="{StaticResource OutlinedButton}" Padding="16,8" Margin="0,0,8,0" />
                        <Button Content="HAPUS STAMP" Command="{Binding RemoveStampCommand}"
                                Style="{StaticResource OutlinedButton}" Padding="16,8" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Language -->
            <TextBlock Text="BAHASA" Style="{StaticResource MicroLabel}" Margin="0,0,0,8" />
            <Border Style="{StaticResource Card}" Margin="0,0,0,24">
                <StackPanel>
                    <ComboBox SelectedItem="{Binding SelectedLanguage}" ItemsSource="{StaticResource Languages}"
                              Style="{StaticResource FieldCombo}" Width="240" HorizontalAlignment="Left" />
                    <TextBlock Text="Perubahan bahasa diterapkan setelah mulai ulang."
                               Style="{StaticResource MutedText}" Margin="0,12,0,0"
                               Visibility="{Binding LanguageChangedRequiresRestart, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
