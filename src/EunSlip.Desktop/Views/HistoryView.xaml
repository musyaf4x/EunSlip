<UserControl x:Class="EunSlip.Desktop.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:EunSlip.Desktop.Converters"
             xmlns:vm="clr-namespace:EunSlip.Desktop.ViewModels">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <c:NullToBoolConverter x:Key="NullToBool" />
    </UserControl.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Riwayat Batch" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,16" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0" ItemsSource="{Binding Batches}" AutoGenerateColumns="False"
                      IsReadOnly="True" HeadersVisibility="Column"
                      SelectedItem="{Binding SelectedBatch}" Margin="0,0,8,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Periode" Binding="{Binding Period}" Width="90" />
                    <DataGridTextColumn Header="Tanggal" Binding="{Binding PaymentDate}" Width="100" />
                    <DataGridTextColumn Header="Penerima" Binding="{Binding RecipientCount}" Width="60" />
                    <DataGridTextColumn Header="Terkirim" Binding="{Binding SentCount}" Width="60" />
                    <DataGridTextColumn Header="Gagal" Binding="{Binding FailedCount}" Width="50" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" />
                </DataGrid.Columns>
            </DataGrid>

            <DataGrid Grid.Column="1" ItemsSource="{Binding SelectedRecipients}" AutoGenerateColumns="False"
                      IsReadOnly="True" HeadersVisibility="Column" Margin="8,0,0,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="NIK (hint)" Binding="{Binding NikHint}" Width="100" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" />
                    <DataGridTextColumn Header="Diperbarui" Binding="{Binding LastUpdatedAtUtc}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <StackPanel Grid.Row="2" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="Kirim Ulang Gagal" Command="{Binding RetryFailedCommand}"
                        CommandParameter="{Binding SelectedBatch}" Padding="12,4" Margin="0,0,8,0"
                        IsEnabled="{Binding SelectedBatch, Converter={StaticResource NullToBool}}" />
                <Button Content="Pulihkan" Command="{Binding RecoverCommand}"
                        CommandParameter="{Binding SelectedBatch}" Padding="12,4" Margin="0,0,8,0"
                        IsEnabled="{Binding SelectedBatch, Converter={StaticResource NullToBool}}" />
                <Button Content="Hapus" Command="{Binding RequestDeleteCommand}"
                        CommandParameter="{Binding SelectedBatch}" Padding="12,4"
                        IsEnabled="{Binding SelectedBatch, Converter={StaticResource NullToBool}}" />
            </StackPanel>

            <Border Background="#FFF8E1" BorderBrush="#FFC107" BorderThickness="1" Padding="12,8"
                    Visibility="{Binding ConfirmDelete, Converter={StaticResource BoolToVis}}" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Hapus permanen batch ini? Riwayat tak bisa dikembalikan." VerticalAlignment="Center" Margin="0,0,12,0" />
                    <Button Content="Hapus Permanen" Command="{Binding ConfirmDeleteBatchCommand}" Padding="10,3" Margin="0,0,8,0" />
                    <Button Content="Batal" Command="{Binding CancelDeleteCommand}" Padding="10,3" />
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding StatusMessage}" Foreground="#555" />
        </StackPanel>
    </Grid>
</UserControl>
