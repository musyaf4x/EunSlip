<UserControl x:Class="EunSlip.Desktop.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Background="{StaticResource PaperWhiteBrush}">
        <StackPanel Margin="40,32">
            <TextBlock Text="Beranda" Style="{StaticResource DisplayHeading}" FontSize="28" Margin="0,0,0,24" />
            <Border Style="{StaticResource Card}" MaxWidth="560" HorizontalAlignment="Left">
                <StackPanel>
                    <TextBlock Text="STATUS" Style="{StaticResource MicroLabel}" Margin="0,0,0,12" />
                    <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,6">
                        <Run Text="Gmail: " /><Run Text="{Binding ConnectedGmail}" FontWeight="SemiBold" Foreground="{StaticResource GraphiteBrush}" />
                    </TextBlock>
                    <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,6">
                        <Run Text="Terkoneksi: " /><Run Text="{Binding HasGmailConnection}" FontWeight="SemiBold" Foreground="{StaticResource GraphiteBrush}" />
                    </TextBlock>
                    <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,0">
                        <Run Text="Stamp siap: " /><Run Text="{Binding HasStamp}" FontWeight="SemiBold" Foreground="{StaticResource GraphiteBrush}" />
                    </TextBlock>
                </StackPanel>
            </Border>
            <TextBlock Text="{Binding InterruptedBatchNotice}" Style="{StaticResource BodyText}"
                       Foreground="{StaticResource EmberRedBrush}" Margin="0,16,0,0" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
