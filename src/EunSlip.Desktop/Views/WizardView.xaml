<UserControl x:Class="EunSlip.Desktop.Views.WizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:EunSlip.Desktop.ViewModels"
             xmlns:loc="clr-namespace:EunSlip.Desktop.Localization"
             xmlns:c="clr-namespace:EunSlip.Desktop.Converters">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <c:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
        <c:StatusTextConverter x:Key="StatusText" />

        <Style x:Key="ProgressStep" TargetType="Border">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource MistBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{StaticResource RadiusPill}" />
            <Setter Property="Padding" Value="12,8" />
        </Style>

        <DataTemplate x:Key="SelectStep" DataType="{x:Type vm:PayrollWizardViewModel}">
            <Grid MaxWidth="820">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,16"
                        Visibility="{Binding IsResumeMode, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc Wizard_ResumeMode}" Style="{StaticResource MicroLabel}" />
                        <TextBlock Text="{Binding RunMode, Converter={StaticResource StatusText}}"
                                   Style="{StaticResource SectionHeading}" Margin="0,6,0,0" />
                        <TextBlock Text="{loc:Loc Wizard_ResumeDescription}"
                                   Style="{StaticResource MutedText}" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc Wizard_PayrollFile}" Style="{StaticResource MicroLabel}" />
                        <Grid Margin="0,10,0,22">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox AutomationProperties.AutomationId="PayrollFilePath"
                                     AutomationProperties.Name="{loc:Loc Wizard_PayrollFileAutomationName}"
                                     Text="{Binding SelectedFilePath, UpdateSourceTrigger=PropertyChanged}"
                                     IsReadOnly="True" Style="{StaticResource FieldInput}" Margin="0,0,10,0" />
                            <Button Grid.Column="1" AutomationProperties.AutomationId="PickPayrollFile"
                                    Content="{loc:Loc Wizard_SelectFile}" Click="PickFile_Click"
                                    Style="{StaticResource OutlinedButton}" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{loc:Loc Wizard_PayrollPeriod}" Style="{StaticResource MicroLabel}" Margin="0,0,0,8" />
                                <TextBox AutomationProperties.AutomationId="PayrollPeriod"
                                         AutomationProperties.Name="{loc:Loc Wizard_PayrollPeriodAutomationName}"
                                         Text="{Binding Period, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FieldInput}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{loc:Loc Wizard_PaymentDate}" Style="{StaticResource MicroLabel}" Margin="0,0,0,8" />
                                <DatePicker AutomationProperties.AutomationId="PaymentDate"
                                            AutomationProperties.Name="{loc:Loc Wizard_PaymentDateAutomationName}"
                                            SelectedDate="{Binding PaymentDate}" Style="{StaticResource FieldPicker}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock Grid.Row="2" Text="{loc:Loc Wizard_SelectConsistencyNote}"
                           Style="{StaticResource MutedText}" Margin="0,12,0,0" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ValidateStep" DataType="{x:Type vm:PayrollWizardViewModel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                    <Border Style="{StaticResource StatusBadge}" Margin="0,0,8,0">
                        <TextBlock Style="{StaticResource LabelText}">
                            <Run Text="{loc:Loc Wizard_RecipientsCount}" /><Run Text="  " /><Run Text="{Binding RecipientCount, Mode=OneWay}" />
                        </TextBlock>
                    </Border>
                    <Border Style="{StaticResource StatusBadge}"
                            Visibility="{Binding IsResumeMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{loc:Loc Wizard_EligibleRecipients}" Style="{StaticResource LabelText}" />
                    </Border>
                </StackPanel>
                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                    <DataGrid AutomationProperties.AutomationId="ValidationGrid"
                              ItemsSource="{Binding ValidationRows}" Style="{StaticResource EditorialDataGrid}"
                              AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{loc:Loc Grid_Row}" Binding="{Binding RowNumber}" Width="60" />
                            <DataGridTextColumn Header="NIK" Binding="{Binding Nik}" Width="110" />
                            <DataGridTextColumn Header="{loc:Loc Grid_Name}" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="EMAIL" Binding="{Binding Email}" Width="*" />
                            <DataGridTextColumn Header="{loc:Loc Grid_Issue}" Binding="{Binding IssueSummary}" Width="210" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
                <CheckBox Grid.Row="2" IsChecked="{Binding WarningConfirmed}" Margin="0,14,0,0"
                          Content="{loc:Loc Wizard_WarningConfirmation}"
                          Visibility="{Binding HasWarnings, Converter={StaticResource BoolToVis}}" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="PreviewStep" DataType="{x:Type vm:PayrollWizardViewModel}">
            <Grid MaxWidth="900">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc Wizard_EmailDelivery}" Style="{StaticResource MicroLabel}" />
                        <TextBlock Text="{loc:Loc Wizard_Subject}" Style="{StaticResource LabelText}" Margin="0,16,0,8" />
                        <TextBox Text="{Binding EmailSubject, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FieldInput}" />
                        <TextBlock Text="{loc:Loc Wizard_EmailBody}" Style="{StaticResource LabelText}" Margin="0,18,0,8" />
                        <TextBox Text="{Binding EmailBody, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="180"
                                 VerticalScrollBarVisibility="Auto" Style="{StaticResource FieldInput}" />
                    </StackPanel>
                </Border>
                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc Wizard_PayslipPreview}" Style="{StaticResource MicroLabel}" />
                            <TextBlock Text="{loc:Loc Wizard_PreviewDescription}"
                                       Style="{StaticResource MutedText}" Margin="0,8,0,14" TextWrapping="Wrap" />
                            <Button AutomationProperties.AutomationId="PreviewPdf"
                                    Content="{loc:Loc ButtonOpenPreview}" Click="OpenPreview_Click"
                                    IsEnabled="{Binding CanGeneratePreview}"
                                    Style="{StaticResource OutlinedButton}" HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc Wizard_Summary}" Style="{StaticResource MicroLabel}" />
                            <TextBlock Style="{StaticResource BodyText}" Margin="0,14,0,8">
                                <Run Text="{loc:Loc Wizard_RecipientsPrefix}" /><Run Text="{Binding RecipientCount, Mode=OneWay}" FontWeight="SemiBold" />
                            </TextBlock>
                            <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,8">
                                <Run Text="{loc:Loc Wizard_GmailPrefix}" /><Run Text="{Binding GmailStatusText, Mode=OneWay}" FontWeight="SemiBold" />
                            </TextBlock>
                            <TextBlock Style="{StaticResource BodyText}">
                                <Run Text="{loc:Loc Wizard_StampPrefix}" /><Run Text="{Binding StampStatusText, Mode=OneWay}" FontWeight="SemiBold" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ConfirmStep" DataType="{x:Type vm:PayrollWizardViewModel}">
            <Grid MaxWidth="820">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc Wizard_BatchSummary}" Style="{StaticResource MicroLabel}" />
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,16,0,10">
                            <Run Text="{loc:Loc Wizard_Period}" /><LineBreak /><Run Text="{Binding Period}" FontWeight="SemiBold" />
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,10">
                            <Run Text="{loc:Loc Wizard_Recipients}" /><LineBreak /><Run Text="{Binding RecipientCount, Mode=OneWay}" FontWeight="SemiBold" />
                        </TextBlock>
                        <TextBlock Style="{StaticResource BodyText}">
                            <Run Text="{loc:Loc Wizard_GmailAccount}" /><LineBreak /><Run Text="{Binding ConnectedGmail}" FontWeight="SemiBold" />
                        </TextBlock>
                    </StackPanel>
                </Border>
                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc Wizard_SendPrerequisites}" Style="{StaticResource MicroLabel}" />
                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Loc Wizard_GmailConnected}" Style="{StaticResource BodyText}" />
                                <Border Grid.Column="1" Style="{StaticResource StatusBadge}">
                                    <TextBlock Text="{Binding GmailStatusText}" Style="{StaticResource LabelText}" />
                                </Border>
                            </Grid>
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{loc:Loc Wizard_CompanyStamp}" Style="{StaticResource BodyText}" />
                                <Border Grid.Column="1" Style="{StaticResource StatusBadge}">
                                    <TextBlock Text="{Binding StampStatusText}" Style="{StaticResource LabelText}" />
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource FogBrush}" BorderBrush="{StaticResource EmberRedBrush}"
                            BorderThickness="2,0,0,0" Padding="16,12" Margin="0,14,0,14">
                        <TextBlock Text="{loc:Loc ConfirmCannotStop}"
                                   Style="{StaticResource BodyText}" TextWrapping="Wrap" />
                    </Border>
                    <Button AutomationProperties.AutomationId="ConfirmSend"
                            Content="{loc:Loc ButtonConfirmSend}" Command="{Binding ConfirmSendCommand}"
                            Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch" />
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="SendStep" DataType="{x:Type vm:PayrollWizardViewModel}">
            <Grid MaxWidth="760">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc Wizard_Sending}" Style="{StaticResource MicroLabel}" />
                        <TextBlock Style="{StaticResource DisplayHeading}" FontSize="42" Margin="0,12,0,14">
                            <Run Text="{Binding CurrentRecipient}" /><Run Text=" / " /><Run Text="{Binding TotalRecipients}" />
                        </TextBlock>
                        <ProgressBar Minimum="0" Maximum="{Binding TotalRecipients}"
                                     Value="{Binding CurrentRecipient}" Height="8" />
                        <Grid Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{loc:Loc Wizard_CurrentRecipient}" Style="{StaticResource MicroLabel}" />
                                <TextBlock Style="{StaticResource BodyText}" Margin="0,8,0,4">
                                    <Run Text="{loc:Loc Wizard_LastNikPrefix}" /><Run Text="{Binding CurrentNik}" FontWeight="SemiBold" />
                                </TextBlock>
                                <TextBlock Text="{Binding CurrentName}" Style="{StaticResource BodyText}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{loc:Loc Wizard_Progress}" Style="{StaticResource MicroLabel}" />
                                <TextBlock Style="{StaticResource BodyText}" Margin="0,8,0,4">
                                    <Run Text="{loc:Loc Wizard_SentPrefix}" /><Run Text="{Binding SentCount}" FontWeight="SemiBold" />
                                    <Run Text="   " /><Run Text="{loc:Loc Wizard_FailedPrefix}" /><Run Text="{Binding FailedCount}" FontWeight="SemiBold" />
                                </TextBlock>
                                <TextBlock Style="{StaticResource MutedText}">
                                    <Run Text="{loc:Loc Wizard_CurrentAttemptPrefix}" /><Run Text="{Binding CurrentAttempt}" />
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Background="{StaticResource FogBrush}" BorderBrush="{StaticResource EmberRedBrush}"
                        BorderThickness="2,0,0,0" Padding="16,12" Margin="0,14,0,0">
                    <TextBlock Text="{loc:Loc Wizard_DoNotClose}"
                               Style="{StaticResource BodyText}" />
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ResultsStep" DataType="{x:Type vm:PayrollWizardViewModel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource SectionHeading}" Margin="0,0,28,0">
                            <Run Text="{loc:Loc Wizard_Sent}" /><Run Text="  " /><Run Text="{Binding SentCount}" />
                        </TextBlock>
                        <TextBlock Style="{StaticResource SectionHeading}">
                            <Run Text="{loc:Loc Wizard_Failed}" /><Run Text="  " /><Run Text="{Binding FailedCount}" Foreground="{StaticResource EmberRedBrush}" />
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                    <DataGrid AutomationProperties.AutomationId="ResultsGrid"
                              ItemsSource="{Binding Results}" Style="{StaticResource EditorialDataGrid}"
                              AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="NIK" Binding="{Binding Nik}" Width="110" />
                            <DataGridTextColumn Header="{loc:Loc Grid_Name}" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="EMAIL" Binding="{Binding Email}" Width="*" />
                            <DataGridTextColumn Header="{loc:Loc Grid_AttemptsAbbreviation}" Binding="{Binding AttemptsMade}" Width="70" />
                            <DataGridTextColumn Header="{loc:Loc Grid_Reason}" Binding="{Binding ErrorMessage}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{StaticResource PaperWhiteBrush}" Style="{StaticResource PageFrame}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="{loc:Loc Wizard_Title}" Style="{StaticResource PageTitle}" />
                <TextBlock Text="{loc:Loc Wizard_Subtitle}"
                           Style="{StaticResource PageSubtitle}" />
            </StackPanel>
            <Border Grid.Column="1" Style="{StaticResource StatusBadge}" VerticalAlignment="Bottom">
                <TextBlock Text="{Binding StepTitle}" Style="{StaticResource LabelText}" />
            </Border>
        </Grid>

        <UniformGrid Grid.Row="1" Columns="6" Margin="0,18,0,18">
            <Border Margin="0,0,6,0">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource ProgressStep}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding StepIndex}" Value="0"><Setter Property="BorderBrush" Value="{StaticResource EmberRedBrush}" /><Setter Property="BorderThickness" Value="2" /></DataTrigger>
                            <DataTrigger Binding="{Binding StepIndex}" Value="1"><Setter Property="Background" Value="{StaticResource FogBrush}" /></DataTrigger>
                            <DataTrigger Binding="{Binding StepIndex}" Value="2"><Setter Property="Background" Value="{StaticResource FogBrush}" /></DataTrigger>
                            <DataTrigger Binding="{Binding StepIndex}" Value="3"><Setter Property="Background" Value="{StaticResource FogBrush}" /></DataTrigger>
                            <DataTrigger Binding="{Binding StepIndex}" Value="4"><Setter Property="Background" Value="{StaticResource FogBrush}" /></DataTrigger>
                            <DataTrigger Binding="{Binding StepIndex}" Value="5"><Setter Property="Background" Value="{StaticResource FogBrush}" /></DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{loc:Loc Wizard_StepSelect}" Style="{StaticResource LabelText}" TextAlignment="Center" />
            </Border>
            <Border Margin="0,0,6,0">
                <Border.Style><Style TargetType="Border" BasedOn="{StaticResource ProgressStep}"><Style.Triggers>
                    <DataTrigger Binding="{Binding StepIndex}" Value="1"><Setter Property="BorderBrush" Value="{StaticResource EmberRedBrush}" /><Setter Property="BorderThickness" Value="2" /></DataTrigger>
                    <DataTrigger Binding="{Binding StepIndex}" Value="2"><Setter Property="Background" Value="{StaticResource FogBrush}" /></DataTrigger>
                    <DataTrigger Binding="{Binding StepIndex}" Value="3"><Setter Property="Background" Value="{StaticResource FogBrush}" /></DataTrigger>
                    <DataTrigger Binding="{Binding StepIndex}" Value="4"><Setter Property="Background" Value="{StaticResource FogBrush}" /></DataTrigger>
                    <DataTrigger Binding="{Binding StepIndex}" Value="5"><Setter Property="Background" Value="{StaticResource FogBrush}" /></DataTrigger>
                </Style.Triggers></Style></Border.Style>
                <TextBlock Text="{loc:Loc Wizard_StepValidate}" Style="{StaticResource LabelText}" TextAlignment="Center" />
            </Border>
            <Border Margin="0,0,6,0">
                <Border.Style><Style TargetType="Border" BasedOn="{StaticResource ProgressStep}"><Style.Triggers>
                    <DataTrigger Binding="{Binding StepIndex}" Value="2"><Setter Property="BorderBrush" Value="{StaticResource EmberRedBrush}" /><Setter Property="BorderThickness" Value="2" /></DataTrigger>
                    <DataTrigger Binding="{Binding StepIndex}" Value="3"><Setter Property="Background" Value="{StaticResource FogBrush}" /></DataTrigger>
                    <DataTrigger Binding="{Binding StepIndex}" Value="4"><Setter Property="Background" Value="{StaticResource FogBrush}" /></DataTrigger>
                    <DataTrigger Binding="{Binding StepIndex}" Value="5"><Setter Property="Background" Value="{StaticResource FogBrush}" /></DataTrigger>
                </Style.Triggers></Style></Border.Style>
                <TextBlock Text="{loc:Loc Wizard_StepEmail}" Style="{StaticResource LabelText}" TextAlignment="Center" />
            </Border>
            <Border Margin="0,0,6,0">
                <Border.Style><Style TargetType="Border" BasedOn="{StaticResource ProgressStep}"><Style.Triggers>
                    <DataTrigger Binding="{Binding StepIndex}" Value="3"><Setter Property="BorderBrush" Value="{StaticResource EmberRedBrush}" /><Setter Property="BorderThickness" Value="2" /></DataTrigger>
                    <DataTrigger Binding="{Binding StepIndex}" Value="4"><Setter Property="Background" Value="{StaticResource FogBrush}" /></DataTrigger>
                    <DataTrigger Binding="{Binding StepIndex}" Value="5"><Setter Property="Background" Value="{StaticResource FogBrush}" /></DataTrigger>
                </Style.Triggers></Style></Border.Style>
                <TextBlock Text="{loc:Loc Wizard_StepConfirm}" Style="{StaticResource LabelText}" TextAlignment="Center" />
            </Border>
            <Border Margin="0,0,6,0">
                <Border.Style><Style TargetType="Border" BasedOn="{StaticResource ProgressStep}"><Style.Triggers>
                    <DataTrigger Binding="{Binding StepIndex}" Value="4"><Setter Property="BorderBrush" Value="{StaticResource EmberRedBrush}" /><Setter Property="BorderThickness" Value="2" /></DataTrigger>
                    <DataTrigger Binding="{Binding StepIndex}" Value="5"><Setter Property="Background" Value="{StaticResource FogBrush}" /></DataTrigger>
                </Style.Triggers></Style></Border.Style>
                <TextBlock Text="{loc:Loc Wizard_StepSend}" Style="{StaticResource LabelText}" TextAlignment="Center" />
            </Border>
            <Border>
                <Border.Style><Style TargetType="Border" BasedOn="{StaticResource ProgressStep}"><Style.Triggers>
                    <DataTrigger Binding="{Binding StepIndex}" Value="5"><Setter Property="BorderBrush" Value="{StaticResource EmberRedBrush}" /><Setter Property="BorderThickness" Value="2" /></DataTrigger>
                </Style.Triggers></Style></Border.Style>
                <TextBlock Text="{loc:Loc Wizard_StepResults}" Style="{StaticResource LabelText}" TextAlignment="Center" />
            </Border>
        </UniformGrid>

        <Grid Grid.Row="2">
            <ContentControl Content="{Binding}">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="Select"><Setter Property="ContentTemplate" Value="{StaticResource SelectStep}" /></DataTrigger>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="Validate"><Setter Property="ContentTemplate" Value="{StaticResource ValidateStep}" /></DataTrigger>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="Preview"><Setter Property="ContentTemplate" Value="{StaticResource PreviewStep}" /></DataTrigger>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="Confirm"><Setter Property="ContentTemplate" Value="{StaticResource ConfirmStep}" /></DataTrigger>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="Send"><Setter Property="ContentTemplate" Value="{StaticResource SendStep}" /></DataTrigger>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="Results"><Setter Property="ContentTemplate" Value="{StaticResource ResultsStep}" /></DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
            <Border Background="{StaticResource FogBrush}" BorderBrush="{StaticResource EmberRedBrush}"
                    BorderThickness="2,0,0,0" Padding="14,10" VerticalAlignment="Top"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource EmberRedBrush}"
                           Style="{StaticResource BodyText}" TextWrapping="Wrap" />
            </Border>
        </Grid>

        <Grid Grid.Row="3" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{loc:Loc Wizard_ReviewBeforeContinue}"
                       Style="{StaticResource MutedText}" VerticalAlignment="Center" />
            <Button Grid.Column="1" AutomationProperties.AutomationId="WizardBack"
                    Content="{loc:Loc ButtonBack}" Command="{Binding BackCommand}"
                    Style="{StaticResource OutlinedButton}" Margin="0,0,8,0"
                    Visibility="{Binding CanGoBack, Converter={StaticResource BoolToVis}}" />
            <Button Grid.Column="2" AutomationProperties.AutomationId="WizardNext"
                    Content="{loc:Loc ButtonNext}" Command="{Binding NextCommand}"
                    Style="{StaticResource PrimaryButton}"
                    Visibility="{Binding CanGoNext, Converter={StaticResource BoolToVis}}" />
        </Grid>
    </Grid>
</UserControl>
