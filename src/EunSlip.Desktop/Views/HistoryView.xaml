<UserControl x:Class="EunSlip.Desktop.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:EunSlip.Desktop.Converters">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <c:NullToVisibilityConverter x:Key="NullToVis" />
        <c:NullToVisibilityInverseConverter x:Key="NullToVisInverse" />
    </UserControl.Resources>

    <Grid Background="{StaticResource PaperWhiteBrush}" Style="{StaticResource PageFrame}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Riwayat Payroll" Style="{StaticResource PageTitle}" />
                <TextBlock Text="Tinjau hasil per batch, percobaan terakhir, dan tindak lanjut yang aman."
                           Style="{StaticResource PageSubtitle}" />
            </StackPanel>
            <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" Style="{StaticResource MutedText}"
                       VerticalAlignment="Bottom" TextAlignment="Right" MaxWidth="360" TextWrapping="Wrap" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="310" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Margin="20,18,20,14">
                        <TextBlock Text="BATCH" Style="{StaticResource MicroLabel}" />
                        <TextBlock Text="Pilih proses untuk melihat detail pengiriman."
                                   Style="{StaticResource MutedText}" Margin="0,6,0,0" />
                    </StackPanel>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Batches}"
                              Style="{StaticResource EditorialDataGrid}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              SelectedItem="{Binding SelectedBatch}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PERIODE" Binding="{Binding Period}" Width="100" />
                            <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" Width="75" />
                            <DataGridTextColumn Header="KIRIM" Binding="{Binding SentCount}" Width="55" />
                            <DataGridTextColumn Header="GAGAL" Binding="{Binding FailedCount}" Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Margin="20,18,20,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Text="DETAIL PENGIRIMAN" Style="{StaticResource MicroLabel}" />
                            <TextBlock Text="Data sensitif disamarkan; detail teknis tersedia di log."
                                       Style="{StaticResource MutedText}" Margin="0,6,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,14,0,0">
                            <Button Content="KIRIM ULANG GAGAL" Command="{Binding RetryFailedCommand}"
                                    CommandParameter="{Binding SelectedBatch}" Style="{StaticResource OutlinedButton}"
                                    Margin="0,0,8,0" />
                            <Button Content="PULIHKAN" Command="{Binding RecoverCommand}"
                                    CommandParameter="{Binding SelectedBatch}" Style="{StaticResource OutlinedButton}"
                                    Margin="0,0,8,0" />
                            <Button Content="HAPUS" Command="{Binding RequestDeleteCommand}"
                                    CommandParameter="{Binding SelectedBatch}" Style="{StaticResource DangerButton}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1">
                        <DataGrid ItemsSource="{Binding SelectedRecipients}"
                                  Style="{StaticResource EditorialDataGrid}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  Visibility="{Binding SelectedBatch, Converter={StaticResource NullToVis}}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="NIK" Binding="{Binding NikHint}" Width="54" />
                                <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" Width="64" />
                                <DataGridTextColumn Header="TIPE" Binding="{Binding LatestAttemptType}" Width="70" />
                                <DataGridTextColumn Header="PERC." Binding="{Binding LatestAttemptNumber}" Width="44" />
                                <DataGridTextColumn Header="SELESAI" Binding="{Binding LatestAttemptCompletedAtUtc}" Width="96" />
                                <DataGridTextColumn Header="KATEGORI" Binding="{Binding ErrorCategory}" Width="80" />
                                <DataGridTextColumn Header="RINGKASAN" Binding="{Binding ErrorSummary}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock Text="Pilih batch untuk melihat penerima dan percobaan pengiriman."
                                   Style="{StaticResource MutedText}" VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Visibility="{Binding SelectedBatch, Converter={StaticResource NullToVisInverse}}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource FogBrush}"
                BorderBrush="{StaticResource EmberRedBrush}" BorderThickness="2,0,0,0"
                Padding="20,14" Margin="0,16,0,0"
                Visibility="{Binding ConfirmDelete, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Hapus permanen batch ini? Riwayat tidak dapat dikembalikan."
                           Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="HAPUS PERMANEN" Command="{Binding ConfirmDeleteBatchCommand}"
                            Style="{StaticResource DangerButton}" Margin="0,0,8,0" />
                    <Button Content="BATAL" Command="{Binding CancelDeleteCommand}"
                            Style="{StaticResource OutlinedButton}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
