<UserControl x:Class="EunSlip.Desktop.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <ScrollViewer Background="{StaticResource PaperWhiteBrush}" VerticalScrollBarVisibility="Auto">
        <Grid Margin="40,36">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="Selamat datang di EunSlip" Style="{StaticResource DisplayHeading}" FontSize="28" />
                <TextBlock Text="Pengiriman slip gaji karyawan — aman, terenkripsi, terverifikasi."
                           Style="{StaticResource MutedText}" Margin="0,6,0,0" />
                <Border Background="{StaticResource MistBrush}" Height="1" Margin="0,20,0,0" />
            </StackPanel>

            <!-- Status cards -->
            <UniformGrid Grid.Row="1" Columns="3" Rows="1" Margin="0,24,0,0">
                <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="GMAIL" Style="{StaticResource MicroLabel}" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding HasGmailConnection, Mode=OneWay, StringFormat='Terkoneksi: {0}'}"
                                   Style="{StaticResource BodyText}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding ConnectedGmail, Mode=OneWay}" Style="{StaticResource MutedText}"
                                   Margin="0,4,0,0" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="6,0">
                    <StackPanel>
                        <TextBlock Text="STAMP" Style="{StaticResource MicroLabel}" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding HasStamp, Mode=OneWay, StringFormat='Aktif: {0}'}"
                                   Style="{StaticResource BodyText}" FontWeight="SemiBold" />
                        <TextBlock Text="Konfigurasi di Pengaturan" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="BATCH" Style="{StaticResource MicroLabel}" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding RecentBatchSummary, Mode=OneWay}"
                                   Style="{StaticResource BodyText}" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="Batch terbaru" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Interrupted notice -->
            <Border Grid.Row="2" Background="{StaticResource FogBrush}"
                    BorderBrush="{StaticResource EmberRedBrush}" BorderThickness="2,0,0,0"
                    Padding="16,12" Margin="0,24,0,0"
                    Visibility="{Binding InterruptedBatchNotice, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding InterruptedBatchNotice, Mode=OneWay}" Style="{StaticResource BodyText}" />
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
