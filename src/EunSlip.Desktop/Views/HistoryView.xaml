<UserControl x:Class="EunSlip.Desktop.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:EunSlip.Desktop.Converters">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <c:NullToBoolConverter x:Key="NullToBool" />
    </UserControl.Resources>
    <Grid Background="{StaticResource PaperWhiteBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="40,32,40,0">
            <TextBlock Text="Riwayat Batch" Style="{StaticResource DisplayHeading}" FontSize="28" />
            <Border Background="{StaticResource MistBrush}" Height="1" Margin="0,16,0,0" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="40,24,40,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0" Margin="0,0,8,0">
                <DataGrid ItemsSource="{Binding Batches}" Style="{StaticResource EditorialDataGrid}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectedItem="{Binding SelectedBatch}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="PERIODE" Binding="{Binding Period}" Width="90" />
                        <DataGridTextColumn Header="TANGGAL" Binding="{Binding PaymentDate}" Width="100" />
                        <DataGridTextColumn Header="PENERIMA" Binding="{Binding RecipientCount}" Width="70" />
                        <DataGridTextColumn Header="KIRIM" Binding="{Binding SentCount}" Width="60" />
                        <DataGridTextColumn Header="GAGAL" Binding="{Binding FailedCount}" Width="56" />
                        <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="0" Margin="8,0,0,0">
                <DataGrid ItemsSource="{Binding SelectedRecipients}" Style="{StaticResource EditorialDataGrid}"
                          AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="NIK (HINT)" Binding="{Binding NikHint}" Width="120" />
                        <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" Width="100" />
                        <DataGridTextColumn Header="DIPERBARUI" Binding="{Binding LastUpdatedAtUtc}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Margin="40,16,40,32">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="KIRIM ULANG GAGAL" Command="{Binding RetryFailedCommand}"
                        CommandParameter="{Binding SelectedBatch}" Style="{StaticResource OutlinedButton}"
                        Padding="16,8" Margin="0,0,8,0"
                        IsEnabled="{Binding SelectedBatch, Converter={StaticResource NullToBool}}" />
                <Button Content="PULIHKAN" Command="{Binding RecoverCommand}"
                        CommandParameter="{Binding SelectedBatch}" Style="{StaticResource OutlinedButton}"
                        Padding="16,8" Margin="0,0,8,0"
                        IsEnabled="{Binding SelectedBatch, Converter={StaticResource NullToBool}}" />
                <Button Content="HAPUS" Command="{Binding RequestDeleteCommand}"
                        CommandParameter="{Binding SelectedBatch}" Style="{StaticResource OutlinedButton}"
                        Padding="16,8"
                        IsEnabled="{Binding SelectedBatch, Converter={StaticResource NullToBool}}" />
            </StackPanel>

            <Border Background="{StaticResource FogBrush}" BorderBrush="{StaticResource EmberRedBrush}"
                    BorderThickness="2,0,0,0" Padding="16,10" Margin="0,0,0,8"
                    Visibility="{Binding ConfirmDelete, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Hapus permanen batch ini? Riwayat tak bisa dikembalikan."
                               Style="{StaticResource BodyText}" VerticalAlignment="Center" Margin="0,0,16,0" />
                    <Button Content="HAPUS PERMANEN" Command="{Binding ConfirmDeleteBatchCommand}"
                            Style="{StaticResource PrimaryButton}" Padding="14,6" Margin="0,0,8,0" />
                    <Button Content="BATAL" Command="{Binding CancelDeleteCommand}"
                            Style="{StaticResource OutlinedButton}" Padding="14,6" />
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MutedText}" />
        </StackPanel>
    </Grid>
</UserControl>
