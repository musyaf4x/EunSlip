<UserControl x:Class="EunSlip.Desktop.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:EunSlip.Desktop.Localization"
             xmlns:c="clr-namespace:EunSlip.Desktop.Converters">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <c:NullToVisibilityConverter x:Key="NullToVis" />
        <c:NullToVisibilityInverseConverter x:Key="NullToVisInverse" />
        <c:StatusTextConverter x:Key="StatusText" />
    </UserControl.Resources>

    <Grid Background="{StaticResource PaperWhiteBrush}" Style="{StaticResource PageFrame}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="{loc:Loc History_Title}" Style="{StaticResource PageTitle}" />
                <TextBlock Text="{loc:Loc History_Subtitle}"
                           Style="{StaticResource PageSubtitle}" />
            </StackPanel>
            <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" Style="{StaticResource MutedText}"
                       VerticalAlignment="Bottom" TextAlignment="Right" MaxWidth="360" TextWrapping="Wrap" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Margin="20,18,20,14">
                        <TextBlock Text="{loc:Loc History_Batches}" Style="{StaticResource MicroLabel}" />
                        <TextBlock Text="{loc:Loc History_SelectProcess}"
                                   Style="{StaticResource MutedText}" Margin="0,6,0,0" />
                    </StackPanel>
                    <DataGrid Grid.Row="1" AutomationProperties.AutomationId="BatchGrid"
                              ItemsSource="{Binding Batches}"
                              Style="{StaticResource EditorialDataGrid}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              SelectedItem="{Binding SelectedBatch}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{loc:Loc Grid_Period}" Binding="{Binding Period}" Width="14*" />
                            <DataGridTextColumn Header="{loc:Loc Grid_Status}" Binding="{Binding Status, Converter={StaticResource StatusText}}" Width="10*" />
                            <DataGridTextColumn Header="{loc:Loc Grid_Sent}" Binding="{Binding SentCount}" Width="7*" />
                            <DataGridTextColumn Header="{loc:Loc Grid_Failed}" Binding="{Binding FailedCount}" Width="9*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Margin="20,18,20,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Text="{loc:Loc History_DeliveryDetails}" Style="{StaticResource MicroLabel}" />
                            <TextBlock Text="{loc:Loc History_SensitiveDataNote}"
                                       Style="{StaticResource MutedText}" Margin="0,6,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,14,0,0">
                            <Button AutomationProperties.AutomationId="RetryFailed"
                                    Content="{loc:Loc History_RetryFailed}" Command="{Binding RetryFailedCommand}"
                                    CommandParameter="{Binding SelectedBatch}" Style="{StaticResource OutlinedButton}"
                                    Margin="0,0,8,0" />
                            <Button AutomationProperties.AutomationId="RecoverInterrupted"
                                    Content="{loc:Loc History_Recover}" Command="{Binding RecoverCommand}"
                                    CommandParameter="{Binding SelectedBatch}" Style="{StaticResource OutlinedButton}"
                                    Margin="0,0,8,0" />
                            <Button AutomationProperties.AutomationId="RequestDelete"
                                    Content="{loc:Loc Common_Delete}" Command="{Binding RequestDeleteCommand}"
                                    CommandParameter="{Binding SelectedBatch}" Style="{StaticResource DangerButton}" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1">
                        <DataGrid AutomationProperties.AutomationId="RecipientGrid"
                                  ItemsSource="{Binding SelectedRecipients}"
                                  Style="{StaticResource EditorialDataGrid}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  Visibility="{Binding SelectedBatch, Converter={StaticResource NullToVis}}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="NIK" Binding="{Binding NikHint}" Width="8*" />
                                <DataGridTextColumn Header="{loc:Loc Grid_Status}" Binding="{Binding Status, Converter={StaticResource StatusText}}" Width="12*" />
                                <DataGridTextColumn Header="{loc:Loc Grid_Type}" Binding="{Binding LatestAttemptType, Converter={StaticResource StatusText}}" Width="13*" />
                                <DataGridTextColumn Header="{loc:Loc Grid_Attempt}" Binding="{Binding LatestAttemptNumber}" Width="8*" />
                                <DataGridTextColumn Header="{loc:Loc Grid_Time}" Binding="{Binding LatestAttemptCompletedAtUtc}" Width="14*" />
                                <DataGridTextColumn Header="{loc:Loc Grid_CategoryAbbreviation}" Binding="{Binding ErrorCategory}" Width="11*" />
                                <DataGridTextColumn Header="{loc:Loc Grid_Detail}" Binding="{Binding ErrorSummary}" Width="16*" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock Text="{loc:Loc History_SelectBatch}"
                                   Style="{StaticResource MutedText}" VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Visibility="{Binding SelectedBatch, Converter={StaticResource NullToVisInverse}}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource FogBrush}"
                BorderBrush="{StaticResource EmberRedBrush}" BorderThickness="2,0,0,0"
                Padding="20,14" Margin="0,16,0,0"
                Visibility="{Binding ConfirmDelete, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{loc:Loc History_DeleteConfirmation}"
                           Style="{StaticResource BodyText}" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button AutomationProperties.AutomationId="ConfirmDelete"
                            Content="{loc:Loc History_DeletePermanent}" Command="{Binding ConfirmDeleteBatchCommand}"
                            Style="{StaticResource DangerButton}" Margin="0,0,8,0" />
                    <Button AutomationProperties.AutomationId="CancelDelete"
                            Content="{loc:Loc Common_Cancel}" Command="{Binding CancelDeleteCommand}"
                            Style="{StaticResource OutlinedButton}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
