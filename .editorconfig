root = true

[*.cs]
# Project-wide defaults
dotnet_analyzer_diagnostic.category-Style.severity = warning
csharp_style_namespace_declarations = file_scoped
# XML doc comments not required on public APIs
dotnet_diagnostic.CS1591.severity = none
# Low-volume desktop logging; LoggerMessage source-gen overhead not justified
dotnet_diagnostic.CA1848.severity = none
dotnet_diagnostic.CA1873.severity = none
# Expression-bodied vs block body: both styles allowed
dotnet_diagnostic.IDE0021.severity = none
dotnet_diagnostic.IDE0022.severity = none
dotnet_diagnostic.IDE0026.severity = none
dotnet_diagnostic.IDE0027.severity = none
# Windows-only desktop app; platform-guard annotations are noise against the single deployment target
dotnet_diagnostic.CA1416.severity = none
dotnet_diagnostic.CA1422.severity = none
# ExecuteNonQuery return value intentionally unused across repository code
dotnet_diagnostic.IDE0058.severity = none
# Primary constructor preferred where constructor only stores deps
dotnet_diagnostic.IDE0290.severity = none
# VM members may be instance even if static-eligible
dotnet_diagnostic.CA1822.severity = none
dotnet_diagnostic.IDE0390.severity = none
dotnet_diagnostic.IDE0072.severity = none
# if-return vs ternary: both allowed
dotnet_diagnostic.IDE0046.severity = none

[tests/**.cs]
# Underscored test names are intentional (Method_Condition_Expectation)
dotnet_diagnostic.CA1707.severity = none
# var is fine in test bodies
dotnet_diagnostic.IDE0008.severity = none
dotnet_diagnostic.CA1859.severity = none
dotnet_diagnostic.IDE0011.severity = none
# Assert.* return values are commonly ignored in tests
dotnet_diagnostic.IDE0058.severity = none
