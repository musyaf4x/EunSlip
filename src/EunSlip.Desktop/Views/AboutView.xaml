<UserControl x:Class="EunSlip.Desktop.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="32">
        <StackPanel>
            <TextBlock Text="Tentang Aplikasi" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,16" />
            <TextBlock Text="{Binding AppName, StringFormat='Nama: {0}'}" Margin="0,0,0,4" />
            <TextBlock Text="{Binding Version, StringFormat='Versi: {0}'}" Margin="0,0,0,4" />
            <TextBlock Text="{Binding Company, StringFormat='Perusahaan: {0}'}" Margin="0,0,0,4" />
            <TextBlock Text="{Binding LogFolder, StringFormat='Folder log: {0}'}" Margin="0,0,0,4" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
