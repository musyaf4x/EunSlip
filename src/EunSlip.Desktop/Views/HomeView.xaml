<UserControl x:Class="EunSlip.Desktop.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <ScrollViewer Background="{StaticResource PaperWhiteBrush}"
                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Style="{StaticResource PageFrame}" MaxWidth="1040" HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource ObsidianBrush}"
                    CornerRadius="8" Padding="32">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="EUNSLIP PAYROLL DELIVERY" Foreground="{StaticResource PaperWhiteBrush}"
                                   FontFamily="{StaticResource BodyFont}" FontSize="12" FontWeight="Bold" />
                        <TextBlock Text="Proses slip gaji dengan alur yang terverifikasi."
                                   Style="{StaticResource PageTitle}" Foreground="{StaticResource PaperWhiteBrush}"
                                   TextWrapping="Wrap" Margin="0,12,24,0" />
                        <TextBlock Text="Validasi data, tinjau hasil, lalu kirim melalui Gmail payroll."
                                   Style="{StaticResource PageSubtitle}" Foreground="{StaticResource MistBrush}"
                                   TextWrapping="Wrap" Margin="0,8,24,0" />
                    </StackPanel>
                <Button Grid.Column="1" AutomationProperties.AutomationId="StartPayroll"
                        Content="PROSES PAYROLL"
                            Command="{Binding DataContext.GoPayrollCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            Background="{StaticResource PaperWhiteBrush}" Foreground="{StaticResource CarbonInkBrush}"
                            Style="{StaticResource PrimaryButton}" Padding="20,12"
                            VerticalAlignment="Center" />
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="0,28,0,16">
                <TextBlock Text="KESIAPAN SISTEM" Style="{StaticResource MicroLabel}" />
                <TextBlock Text="Pastikan prasyarat pengiriman tersedia."
                           Style="{StaticResource SectionHeading}" Margin="0,8,0,0" />
            </StackPanel>

            <UniformGrid Grid.Row="2" Columns="3" Rows="1">
                <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="GMAIL" Style="{StaticResource MicroLabel}" />
                        <TextBlock Text="{Binding GmailStatusText}" Style="{StaticResource SectionHeading}"
                                   Margin="0,12,0,4" />
                        <TextBlock Text="{Binding ConnectedGmail}" Style="{StaticResource MutedText}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="STAMP" Style="{StaticResource MicroLabel}" />
                        <TextBlock Text="{Binding StampStatusText}" Style="{StaticResource SectionHeading}"
                                   Margin="0,12,0,4" />
                        <TextBlock Text="Dikelola melalui Pengaturan" Style="{StaticResource MutedText}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="BAHASA" Style="{StaticResource MicroLabel}" />
                        <TextBlock Text="{Binding ActiveLanguage}" Style="{StaticResource SectionHeading}"
                                   Margin="0,12,0,4" />
                        <TextBlock Text="Aktif setelah aplikasi dimulai" Style="{StaticResource MutedText}" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="3" Background="{StaticResource FogBrush}"
                    BorderBrush="{StaticResource EmberRedBrush}" BorderThickness="3,0,0,0"
                    Padding="18,16" Margin="0,20,0,0"
                    Visibility="{Binding HasInterruptedBatch, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="TINDAKAN DIPERLUKAN" Style="{StaticResource MicroLabel}"
                               Foreground="{StaticResource EmberRedBrush}" />
                    <TextBlock Text="{Binding InterruptedBatchNotice}" Style="{StaticResource BodyText}"
                               TextWrapping="Wrap" Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource Card}" Margin="0,20,0,0">
                <StackPanel>
                    <TextBlock Text="BATCH TERBARU" Style="{StaticResource MicroLabel}" />
                    <TextBlock Text="{Binding RecentBatchSummary}" Style="{StaticResource SectionHeading}"
                               TextWrapping="Wrap" Margin="0,10,0,0" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
