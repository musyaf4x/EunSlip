<Window x:Class="EunSlip.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:EunSlip.Desktop.ViewModels"
        xmlns:v="clr-namespace:EunSlip.Desktop.Views"
        Title="EunSlip" Width="1180" Height="760" MinWidth="1024" MinHeight="680"
        Background="{StaticResource PaperWhiteBrush}"
        Icon="/EunSlip.Desktop;component/Assets/eunslip-logo-bg-01.png"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <v:HomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PayrollWizardViewModel}">
            <v:WizardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
            <v:HistoryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <v:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AboutViewModel}">
            <v:AboutView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Nav rail (white with hairline border) -->
        <Border Grid.Column="0" Background="{StaticResource PaperWhiteBrush}"
                BorderBrush="{StaticResource MistBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Brand -->
                <Grid Grid.Row="0" Margin="24,28,24,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Source="/EunSlip.Desktop;component/Assets/eunslip-logo-black-01.png"
                           Width="40" Height="40" Stretch="Uniform"
                           AutomationProperties.Name="EunSlip logo"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="EUNSLIP" FontFamily="{StaticResource BodyFont}"
                                   FontSize="22" FontWeight="Bold" Foreground="{StaticResource CarbonInkBrush}" />
                        <TextBlock Text="PAYROLL DELIVERY" FontFamily="{StaticResource BodyFont}"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource GraphiteBrush}" Margin="0,4,0,0"
                                   TextOptions.TextFormattingMode="Display" />
                    </StackPanel>
                </Grid>

                <!-- Nav buttons -->
                <StackPanel Grid.Row="1" Margin="16,0">
                    <Button AutomationProperties.AutomationId="NavHome"
                            Content="{Binding NavHome}" Command="{Binding GoHomeCommand}" Margin="0,2">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHomeActive}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource CarbonInkBrush}" />
                                        <Setter Property="Foreground" Value="{StaticResource PaperWhiteBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button AutomationProperties.AutomationId="NavPayroll"
                            Content="{Binding NavPayrollProcess}" Command="{Binding GoPayrollCommand}" Margin="0,2">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPayrollActive}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource CarbonInkBrush}" />
                                        <Setter Property="Foreground" Value="{StaticResource PaperWhiteBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button AutomationProperties.AutomationId="NavHistory"
                            Content="{Binding NavHistory}" Command="{Binding GoHistoryCommand}" Margin="0,2">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHistoryActive}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource CarbonInkBrush}" />
                                        <Setter Property="Foreground" Value="{StaticResource PaperWhiteBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button AutomationProperties.AutomationId="NavSettings"
                            Content="{Binding NavSettings}" Command="{Binding GoSettingsCommand}" Margin="0,2">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSettingsActive}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource CarbonInkBrush}" />
                                        <Setter Property="Foreground" Value="{StaticResource PaperWhiteBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button AutomationProperties.AutomationId="NavAbout"
                            Content="{Binding NavAbout}" Command="{Binding GoAboutCommand}" Margin="0,2">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAboutActive}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource CarbonInkBrush}" />
                                        <Setter Property="Foreground" Value="{StaticResource PaperWhiteBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Vierth Labs trademark footer -->
                <StackPanel Grid.Row="2" Margin="24,16,24,24">
                    <Border BorderBrush="{StaticResource MistBrush}" BorderThickness="0,1,0,0" Margin="0,0,0,16" />
                    <TextBlock Text="{Binding ActiveLanguage}" Style="{StaticResource MicroLabel}" />
                    <TextBlock Text="{Binding VersionText}" Style="{StaticResource MutedText}" Margin="0,4,0,12" />
                    <Image Source="/Assets/vierth.png" Height="28" HorizontalAlignment="Left"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Text="DEVELOPED BY VIERTH LABS" Style="{StaticResource MicroLabel}"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <ContentControl Grid.Column="1" Content="{Binding Current}" />
    </Grid>
</Window>
