<UserControl x:Class="EunSlip.Desktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:c="clr-namespace:EunSlip.Desktop.Converters"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <c:NullToVisibilityConverter x:Key="NullToVis" />
        <x:Array x:Key="Languages" Type="{x:Type sys:String}">
            <sys:String>id-ID</sys:String>
            <sys:String>en-US</sys:String>
        </x:Array>
    </UserControl.Resources>

    <ScrollViewer Background="{StaticResource PaperWhiteBrush}"
                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Style="{StaticResource PageFrame}" MaxWidth="920" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,0,24">
                <TextBlock Text="Pengaturan" Style="{StaticResource PageTitle}" />
                <TextBlock Text="Kelola koneksi pengiriman, stamp, dan preferensi aplikasi."
                           Style="{StaticResource PageSubtitle}" Margin="0,6,0,0" />
            </StackPanel>

            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="GMAIL" Style="{StaticResource MicroLabel}" />
                    <TextBlock Text="{Binding GmailStatusText}" Style="{StaticResource SectionHeading}"
                               Margin="0,12,0,4" />
                    <TextBlock Text="{Binding ConnectedGmail}" Style="{StaticResource MutedText}"
                               TextTrimming="CharacterEllipsis" />
                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                        <Button AutomationProperties.AutomationId="ConnectGmail"
                                Command="{Binding ConnectGmailCommand}" Margin="0,0,8,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                    <Setter Property="Content" Value="HUBUNGKAN" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnecting}" Value="True">
                                            <Setter Property="Content" Value="MENGHUBUNGKAN…" />
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button AutomationProperties.AutomationId="DisconnectGmail"
                                Content="PUTUSKAN" Command="{Binding DisconnectGmailCommand}"
                                Style="{StaticResource OutlinedButton}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="STAMP" Style="{StaticResource MicroLabel}" />
                    <TextBlock Text="{Binding StampStatusText}" Style="{StaticResource SectionHeading}"
                               Margin="0,12,0,20" />
                    <StackPanel Orientation="Horizontal">
                        <Button AutomationProperties.AutomationId="PickStamp"
                                Content="PILIH GAMBAR" Click="PickStamp_Click"
                                Style="{StaticResource OutlinedButton}" Margin="0,0,8,0" />
                        <Button AutomationProperties.AutomationId="RequestRemoveStamp"
                                Content="HAPUS" Command="{Binding RequestRemoveStampCommand}"
                                Style="{StaticResource DangerButton}" />
                    </StackPanel>
                    <Border Background="{StaticResource FogBrush}" Padding="12" Margin="0,12,0,0"
                            Visibility="{Binding IsRemoveStampConfirmationVisible, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="Hapus stamp aktif? Pengiriman diblokir sampai stamp baru dipilih."
                                       Style="{StaticResource MutedText}" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Button Content="BATAL" Command="{Binding CancelRemoveStampCommand}"
                                        Style="{StaticResource OutlinedButton}" Margin="0,0,8,0" />
                                <Button Content="YA, HAPUS" Command="{Binding ConfirmRemoveStampCommand}"
                                        Style="{StaticResource DangerButton}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource Card}" Margin="0,24,0,0">
                <StackPanel>
                    <TextBlock Text="OAUTH CLIENT" Style="{StaticResource MicroLabel}" />
                    <TextBlock Text="{Binding OauthStatusText}" Style="{StaticResource SectionHeading}"
                               Margin="0,12,0,12" />
                    <TextBox AutomationProperties.AutomationId="OAuthSecretInput"
                             AutomationProperties.Name="OAuth client secret JSON"
                             Text="{Binding OauthClientSecretJson, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FieldInput}" AcceptsReturn="True" MinHeight="64"
                             TextWrapping="Wrap" />
                    <Button AutomationProperties.AutomationId="SaveOAuthSecret"
                            Content="SIMPAN KREDENSIAL" Command="{Binding SaveOAuthSecretCommand}"
                            Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"
                            Margin="0,12,0,0" />
                    <Expander Header="PANDUAN SETUP GOOGLE CLOUD &amp; OAUTH" Margin="0,12,0,0">
                        <Border Background="{StaticResource FogBrush}" Padding="12" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Langkah-langkah:" Style="{StaticResource BodyText}"
                                           FontWeight="SemiBold" Margin="0,0,0,8" />
                                <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,6">
                                    <Run Text="1. Buka " /><Run Text="console.cloud.google.com" /><Run Text=" → buat / pilih project." />
                                </TextBlock>
                                <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,6">
                                    <Run Text="2. APIs &amp; Services → Library → aktifkan " /><Run Text="Gmail API" /><Run Text="." />
                                </TextBlock>
                                <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,6">
                                    <Run Text="3. OAuth consent screen: pilih " /><Run Text="Internal" /><Run Text=" (jika Google Workspace), isi app name &amp; email." />
                                </TextBlock>
                                <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,6">
                                    <Run Text="4. Credentials → Create Credentials → OAuth client ID → type " /><Run Text="Desktop app" /><Run Text="." />
                                </TextBlock>
                                <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,6">
                                    <Run Text="5. Download " /><Run Text="client_secret.json" /><Run Text="." />
                                </TextBlock>
                                <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,6">
                                    <Run Text="6. Buka isi file client_secret.json, tempel ke kotak " /><Run Text="OAuth Client" /><Run Text=" di atas, lalu klik Simpan Kredensial." />
                                </TextBlock>
                                <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,0,0,6">
                                    <Run Text="7. Klik " /><Run Text="Hubungkan" /><Run Text=" — browser terbuka, login akun payroll Gmail, lalu izinkan akses." />
                                </TextBlock>
                                <TextBlock Style="{StaticResource MutedText}" TextWrapping="Wrap"
                                           Foreground="{StaticResource EmberRedBrush}">
                                    <Run Text="Catatan: gunakan akun payroll Gmail PT. EUNSUNG INDONESIA. Akun ini menjadi pengirim." />
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Expander>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource Card}" Margin="0,24,0,0">
                <StackPanel>
                    <TextBlock Text="BAHASA" Style="{StaticResource MicroLabel}" />
                    <TextBlock Text="Bahasa antarmuka" Style="{StaticResource SectionHeading}"
                               Margin="0,12,0,12" />
                    <ComboBox AutomationProperties.AutomationId="LanguageSelector"
                              AutomationProperties.Name="Bahasa antarmuka"
                              ItemsSource="{StaticResource Languages}"
                              SelectedItem="{Binding SelectedLanguage}"
                              Style="{StaticResource FieldCombo}" />
                    <TextBlock Text="Perubahan bahasa diterapkan setelah aplikasi dimulai ulang."
                               Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,12,0,0"
                               Visibility="{Binding LanguageChangedRequiresRestart, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Grid.ColumnSpan="3" Background="{StaticResource FogBrush}"
                    BorderBrush="{StaticResource MistBrush}" BorderThickness="1"
                    CornerRadius="4" Padding="14" Margin="0,20,0,0"
                    Visibility="{Binding StatusMessage, Converter={StaticResource NullToVis}}">
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource MutedText}"
                           TextWrapping="Wrap" />
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
